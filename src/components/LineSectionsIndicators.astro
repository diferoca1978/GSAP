---

<section class="py-l6 mx-auto w-full px-6 lg:px-16 lg:py-24">
  <div class="mx-auto max-w-7xl">
    <!-- Kicker -->
    <div class="approach-kicker mb-12 flex items-center gap-3">
      <div class="bg-gray-lavender/50 h-px w-8 shrink-0"></div>
      <span
        class="font-nunito text-gray-lavender text-xs font-semibold tracking-widest uppercase"
      >
        Mis pilares éticos
      </span>
    </div>
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-5">
      <!-- Left side heading -->
      <div class="col-span-2 lg:sticky lg:top-24 lg:self-start">
        <h1 class="text-purple-accent text-4xl font-bold uppercase">
          El suelo firme sobre el que trabajaremos
        </h1>
        <p class="text-purple-dark mt-6 text-lg">
          La psicología es un acto de confianza. Por eso, cada sesión se rige
          por principios éticos inquebrantables que protegen tu proceso y
          respetan tu verdad.
        </p>
      </div>
      <!-- Right side content -->
      <div class="line-sections col-span-3">
        <!-- section 1 -->
        <div
          class="line-section border-gray-lavender/20 flex items-center border-y p-8"
        >
          <div class="text-purple-accent text-4xl font-bold lg:text-9xl">1</div>
          <div
            class="line-holder bg-gray-lavender/20 h-36 w-5 overflow-hidden rounded-xl"
          >
            <div class="line bg-purple-accent h-24 w-full rounded-xl"></div>
          </div>
          <div class="text-purple-dark ml-8 max-w-lg">
            <h2 class="text-purple-accent text-2xl font-bold">
              Verdad y Transparencia
            </h2>
            <p class="text-purple-dark mt-2 text-lg">
              Te hablaré con honestidad clínica. Sin falsas promesas de "curas
              mágicas", pero con el compromiso total de mi experiencia.
            </p>
          </div>
        </div>
        <!-- section 2 -->
        <div
          class="line-section border-gray-lavender/20 flex items-center border-y p-8"
        >
          <div class="text-purple-accent text-4xl font-bold lg:text-9xl">2</div>
          <div
            class="line-holder bg-gray-lavender/20 h-36 w-5 overflow-hidden rounded-xl"
          >
            <div class="line bg-purple-accent h-24 w-full rounded-xl"></div>
          </div>
          <div class="text-purple-dark ml-8 max-w-lg">
            <h2 class="text-purple-accent text-2xl font-bold">
              Confidencialidad Absoluta
            </h2>
            <p class="text-purple-dark mt-2 text-lg">
              Tu historia es sagrada. Nuestro espacio virtual es un refugio
              blindado.
            </p>
          </div>
        </div>
        <!-- section 3 -->
        <div
          class="line-section border-gray-lavender/20 flex items-center border-y p-8"
        >
          <div class="text-purple-accent text-4xl font-bold lg:text-9xl">
            <h1>3</h1>
          </div>
          <div
            class="line-holder bg-gray-lavender/20 h-36 w-5 overflow-hidden rounded-xl"
          >
            <div class="line bg-purple-accent h-24 w-full rounded-xl"></div>
          </div>
          <div class="text-purple-dark ml-8 max-w-lg">
            <h2 class="text-purple-accent text-2xl font-bold">
              Respeto Profundo
            </h2>
            <p class="text-purple-dark mt-2 text-lg">
              Aquí no hay cabida para el juicio. Honro tu ritmo, tus decisiones
              y tu proceso individual.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { eticPillarsAnimation } from "@/scripts/gsapEticPillars";

  eticPillarsAnimation();
</script>

---

<div
  class="description flex items-center justify-center min-h-screen w-full bg-sky-500 p-10"
>
  <h1 class="text-4xl font-bold">Split Screen Pinning</h1>
  <p class="mt-4 text-lg">
    This component demonstrates a split-screen pinning effect using GSAP and
    ScrollTrigger. As you scroll, the panels will pin and unpin, creating a
    dynamic and engaging visual experience.
  </p>
</div>

<div
  id="panel-container"
  class="relative mx-auto h-screen w-full overflow-hidden"
>
  <section
    class="panel green absolute inset-0 flex flex-col items-center justify-center bg-green-500"
  >
    <p class="panel-label text-sm uppercase tracking-widest text-white/70 mb-4">
      01 / Start
    </p>
    <h2 class="panel-title text-6xl font-bold text-white">Begin Here</h2>
    <p class="panel-sub mt-6 text-xl text-white/80 max-w-md text-center">
      Scroll down to explore each step of the journey.
    </p>
  </section>
  <section
    class="panel orange absolute inset-0 flex flex-col items-center justify-center bg-orange-500 will-change-transform"
  >
    <p class="panel-label text-sm uppercase tracking-widest text-white/70 mb-4">
      02 / Discovery
    </p>
    <h2 class="panel-title text-6xl font-bold text-white">Find Your Path</h2>
    <p class="panel-sub mt-6 text-xl text-white/80 max-w-md text-center">
      Every great journey starts with a single step forward.
    </p>
  </section>
  <section
    class="panel purple absolute inset-0 flex flex-col items-center justify-center bg-purple-500 will-change-transform"
  >
    <p class="panel-label text-sm uppercase tracking-widest text-white/70 mb-4">
      03 / Creation
    </p>
    <h2 class="panel-title text-6xl font-bold text-white">Build Something</h2>
    <p class="panel-sub mt-6 text-xl text-white/80 max-w-md text-center">
      Turn your ideas into reality with focused effort and craft.
    </p>
  </section>
  <section
    class="panel blue absolute inset-0 flex flex-col items-center justify-center bg-blue-500 will-change-transform"
  >
    <p class="panel-label text-sm uppercase tracking-widest text-white/70 mb-4">
      04 / Arrival
    </p>
    <h2 class="panel-title text-6xl font-bold text-white">You Made It</h2>
    <p class="panel-sub mt-6 text-xl text-white/80 max-w-md text-center">
      The destination is only the beginning of the next adventure.
    </p>
  </section>
</div>

<script>
  import { pinSlideInAnimation } from "@/scripts/gsapPinSlideInAnimation.js";

  pinSlideInAnimation();
</script>
